# pCube Sharing Debugger — Variabili d'ambiente

# Porta su cui ascolta il server (default: 3333)
# PORT=4444

# Indirizzo su cui si bind il server (default: 127.0.0.1)
# In Docker va impostato a 0.0.0.0 (già fatto in docker-compose.yml)
# HOST=0.0.0.0

# Controllo del logging su logs/requests.log
#   all   — logga ogni richiesta (GET, POST, statici, favicon…)
#   none  — non logga nulla
#   debug — solo richieste POST /api/debug
# Default: all
# REQUEST_LOG=debug

# Percorso dell'eseguibile Chromium per Puppeteer
# Utile quando Chromium non è nel PATH o si vuole usare un installazione diversa.
# Nel Dockerfile è impostato a /usr/bin/chromium.
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Ambiente (produzione / sviluppo)
# In produzione (Docker) rejectUnauthorized per HTTPS è attivo.
# NODE_ENV=production
