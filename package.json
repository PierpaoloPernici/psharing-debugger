{
  "name": "sharing-debugger",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Local preview of how a URL appears when shared on social networks",
  "scripts": {
    "build:css": "tailwindcss -i src/input.css -o public/style.css --minify",
    "watch:css": "tailwindcss -i src/input.css -o public/style.css --watch",
    "start": "npm run build:css && node server.mjs",
    "dev": "node --watch server.mjs & tailwindcss -i src/input.css -o public/style.css --watch"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^4.21.0",
    "open": "^10.0.0",
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.6"
  }
}
